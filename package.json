{
  "name": "speakmore-app",
  "private": true,
  "version": "0.1.2",
  "description": "Local-first desktop speech-to-text application",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OrigArith/SpeakMore.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write . && cd src-tauri && cargo fmt",
    "format:check": "prettier --check . && cd src-tauri && cargo fmt -- --check",
    "format:frontend": "prettier --write .",
    "format:backend": "cd src-tauri && cargo fmt",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "check:translations": "bun scripts/check-translations.ts",
    "preflight:source-release": "bun scripts/source-release-preflight.ts",
    "postinstall": "bun scripts/check-nix-deps.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-fs": "~2.4.5",
    "@tauri-apps/plugin-global-shortcut": "~2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-sql": "~2.3.2",
    "@tauri-apps/plugin-store": "~2.4.3",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "i18next": "^25.10.10",
    "immer": "^11.1.8",
    "lucide-react": "^0.542.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.6",
    "react-select": "^5.10.2",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0",
    "tauri-plugin-macos-permissions-api": "2.3.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.12.4",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@types/react-select": "^5.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "~5.6.3",
    "vite": "^6.4.2"
  },
  "overrides": {
    "brace-expansion": "^1.1.14",
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "rollup": "^4.60.4",
    "yaml": "1.10.3"
  }
}
